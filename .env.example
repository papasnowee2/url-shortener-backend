# Server
PORT=3000
NODE_ENV=development

# Frontend origin allowed to send cookies (CORS with credentials)
CLIENT_ORIGIN=http://localhost:5173

# MongoDB (runs locally on its default port 27017)
MONGODB_URI=mongodb://127.0.0.1:27017/url-shortener

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Cookie lifetime in milliseconds (defaults to 7 days)
COOKIE_MAX_AGE=604800000

# External (third-party) short link provider.
# Supported (no API key): "cleanuri" (default), "isgd", "spoome"
# Supported (needs key):  "tinyurl"
SHORTENER_PROVIDER=cleanuri
# Required only when SHORTENER_PROVIDER=tinyurl
TINYURL_API_TOKEN=
